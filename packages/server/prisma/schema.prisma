// ============================================================
// Schéma Prisma — IDLE Infinite Quest V2
// Base de données : PostgreSQL
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Modèle User — Le voyageur
// ============================================================
model User {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String   @unique
  password  String
  role      Role     @default(USER)

  // --- Progression ---
  level     Int      @default(1)
  xp        Int      @default(0)
  gold      Int      @default(100)
  crystals  Int      @default(0)
  
  // --- Auth Pro & Social ---
  googleId   String?  @unique
  facebookId String?  @unique
  avatarUrl  String?
  
  // --- Moderation Status ---
  status     UserStatus @default(ACTIVE)
  bannedAt   DateTime?
  banExpires DateTime?
  banReason  String?
  language   String   @default("fr")


  // --- Timestamps ---
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lastLogin DateTime @default(now())
  
  // --- Monetization & Pass ---
  creatorPassUntil DateTime?
  creatorScore     Int       @default(0)
  isBanned         Boolean   @default(false)

  // --- Relations ---
  inventory       InventoryInstance[]
  createdItems    ItemTemplate[]       @relation("ItemCreator")
  auctionListings AuctionListing[]
  chatMessages    ChatMessage[]
  
  // --- Guild / Social ---
  guildId         String?
  guild           Guild?               @relation(fields: [guildId], references: [id])
  guildRole       GuildRole?
  forumTopics     ForumTopic[]
  forumPosts      ForumPost[]
  
  // --- UGC Dungeons ---
  createdMonsters MonsterTemplate[]    @relation("MonsterCreator")
  createdDungeons DungeonTemplate[]    @relation("DungeonCreator")

  @@index([username])
  @@map("users")
}

// ============================================================
// Enum Role — Hiérarchie stricte
// ============================================================
enum Role {
  USER
  MODERATOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  BANNED
  SUSPENDED
  SHADOWBANNED
}

// ============================================================
// Modèle ItemTemplate — Blueprint d'un item (créé par le Workshop ou le système)
// ============================================================
model ItemTemplate {
  id          String     @id @default(cuid())
  name        String
  description String?
  slot        String     // HEAD, BODY, LEGS, etc.
  rarity      Rarity     @default(COMMON)

  // --- Stats de base ---
  attack      Int        @default(0)
  defense     Int        @default(0)
  hp          Int        @default(0)
  critChance  Float      @default(0)
  dodge       Float      @default(0)
  haste       Float      @default(0)

  // --- Visuel ---
  spriteUrl   String?    // URL vers MinIO (jamais de base64 ici !)

  // --- Workshop / UGC ---
  status      ItemStatus @default(APPROVED)
  isUGC       Boolean    @default(false)
  creatorId   String?
  creator     User?      @relation("ItemCreator", fields: [creatorId], references: [id])
  likes       Int        @default(0) // Nombre de joueurs qui admirent l'objet

  // --- Boutique ---
  shopPrice   Int?       // Null = non achetable en boutique
  dropTier    Int?       // Tier minimum pour que le monstre le drop

  // --- Timestamps ---
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // --- Relations ---
  instances       InventoryInstance[]
  auctionListings AuctionListing[]

  @@index([slot])
  @@index([rarity])
  @@index([status])
  @@map("item_templates")
}

// ============================================================
// Enum Rarity
// ============================================================
enum Rarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
}

// ============================================================
// Enum ItemStatus — Statut de modération Workshop
// ============================================================
enum ItemStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

// ============================================================
// Modèle InventoryInstance — Instance unique d'un item possédé par un joueur
// Plus jamais de JSON dans User ! C'est une vraie table relationnelle.
// ============================================================
model InventoryInstance {
  id          String       @id @default(cuid())

  // --- Propriétaire ---
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  // --- Template de base ---
  templateId  String
  template    ItemTemplate @relation(fields: [templateId], references: [id])

  // --- État de l'instance ---
  isEquipped  Boolean      @default(false)
  quantity    Int          @default(1)

  // --- Personnalisation visuelle (filtres CSS) ---
  hueRotate   Float?       // degrés de rotation de teinte
  brightness  Float?       // luminosité
  saturate    Float?       // saturation

  // --- Timestamps ---
  acquiredAt  DateTime     @default(now())

  @@unique([userId, templateId, isEquipped]) // Un joueur ne peut équiper qu'un item par template
  @@index([userId])
  @@index([templateId])
  @@map("inventory_instances")
}

// ============================================================
// Modèle AuctionListing — Hôtel de Vente (Joueurs vendent aux joueurs)
// ============================================================
model AuctionListing {
  id          String       @id @default(cuid())
  
  // Vendeur
  sellerId    String
  seller      User         @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  
  // Objet en vente
  templateId  String
  template    ItemTemplate @relation(fields: [templateId], references: [id])
  
  // Prix et Quantité
  price       Int          // Prix total pour le lot
  quantity    Int          @default(1)
  
  // Statut
  status      AuctionStatus @default(ACTIVE)
  
  createdAt   DateTime     @default(now())

  @@index([sellerId])
  @@index([templateId])
  @@index([status])
  @@map("auction_listings")
}

enum AuctionStatus {
  ACTIVE
  SOLD
  CANCELLED
}

// ============================================================
// Modèle ChatMessage — Taverne Mondiale (Chat Global)
// ============================================================
model ChatMessage {
  id        String   @id @default(cuid())
  
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  
  content   String   @db.VarChar(500) // Limite de 500 caractères
  channel   String   @default("global") // global, guilde, system...
  
  createdAt DateTime @default(now())

  @@index([channel])
  @@index([createdAt])
  @@map("chat_messages")
}

// ============================================================
// Modèle SystemConfig — Configuration dynamique du Royaume (Phase 7)
// ============================================================
model SystemConfig {
  key         String   @id // ex: XP_MULTIPLIER, DROP_RATE_MODIFIER
  value       String   // Stocké en string, casté selon le besoin
  description String?
  updatedAt   DateTime @updatedAt

  @@map("system_config")
}

// ============================================================
// Modèles Guildes & Social (Phase 8/10)
// ============================================================

model Guild {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  icon        String?  // URL ou ID d'icône
  level       Int      @default(1)
  xp          Int      @default(0)
  
  // Membres
  members     User[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("guilds")
}

enum GuildRole {
  LEADER
  OFFICER
  MEMBER
}

// ============================================================
// Modèles Forum "La Taverne"
// ============================================================

model ForumCategory {
  id          String       @id @default(cuid())
  name        String
  description String?
  order       Int          @default(0)
  topics      ForumTopic[]

  @@map("forum_categories")
}

model ForumTopic {
  id          String        @id @default(cuid())
  title       String
  
  categoryId  String
  category    ForumCategory @relation(fields: [categoryId], references: [id])
  
  authorId    String
  author      User          @relation(fields: [authorId], references: [id])
  
  posts       ForumPost[]
  
  isPinned    Boolean       @default(false)
  isLocked    Boolean       @default(false)
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([categoryId])
  @@index([authorId])
  @@map("forum_topics")
}

model ForumPost {
  id          String     @id @default(cuid())
  content     String     @db.Text
  
  topicId     String
  topic       ForumTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  
  authorId    String
  author      User       @relation(fields: [authorId], references: [id])
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([topicId])
  @@index([authorId])
  @@map("forum_posts")
}

// ============================================================
// Modèles Donjons & Monstres (Phase 9)
// ============================================================

model MonsterTemplate {
  id          String         @id @default(cuid())
  name        String
  spriteUrl   String         // Image 64x64
  category    MonsterCategory @default(MINION)
  
  // UGC
  isUGC       Boolean        @default(false)
  status      ItemStatus     @default(APPROVED)
  creatorId   String?
  creator     User?          @relation("MonsterCreator", fields: [creatorId], references: [id])

  dungeonsAsMinion DungeonTemplate[] @relation("MinionTemplate")
  dungeonsAsBoss   DungeonTemplate[] @relation("BossTemplate")

  createdAt   DateTime       @default(now())

  @@map("monster_templates")
}

enum MonsterCategory {
  MINION
  BOSS
}

model DungeonTemplate {
  id            String   @id @default(cuid())
  name          String
  description   String?
  backgroundUrl String?  // Image de fond du donjon
  
  // Composition
  minionTemplateId String
  minionTemplate   MonsterTemplate @relation("MinionTemplate", fields: [minionTemplateId], references: [id])
  
  bossTemplateId   String
  bossTemplate     MonsterTemplate @relation("BossTemplate", fields: [bossTemplateId], references: [id])

  // UGC
  isUGC         Boolean  @default(false)
  status        ItemStatus @default(APPROVED)
  creatorId     String?
  creator       User?    @relation("DungeonCreator", fields: [creatorId], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("dungeon_templates")
}
